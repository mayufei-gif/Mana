# CourseMind NAS 配置示例

# Windows 本机运行时可用映射盘或 SMB 路径：
# VIDEO_ROOT=Z:/网课视频
# VIDEO_ROOT=\\192.168.1.100\网课视频
# Docker/NAS 容器内固定使用 /videos；长期上传入口固定使用 /videos_upload
VIDEO_ROOT=./sample_videos
NAS_VIDEO_DIR=./sample_videos
COURSEMIND_VIDEO_DIR=./sample_videos
VIDEO_ROOTS=./sample_videos
NAS_VIDEO_DIRS=./sample_videos
COURSEMIND_VIDEO_DIRS=./sample_videos

# 数据库、字幕、音频缓存、笔记输出目录。
# Docker/NAS 容器内建议：
# VIDEO_ROOT=/videos
# DATA_DIR=/data
# PROCESSED_DIR=/processed
# LOG_DIR=/logs
# CONFIG_DIR=/config
# DATABASE_URL=sqlite:////data/coursemind.db
DATA_DIR=./storage/data
PROCESSED_DIR=./storage/processed
LOG_DIR=./storage/logs
CONFIG_DIR=./config
STORAGE_DIR=./storage/processed
COURSEMIND_STORAGE_DIR=./storage/processed
COURSEMIND_DB_PATH=./storage/data/coursemind.db
DATABASE_URL=

# docker-compose 使用的宿主机挂载目录。NAS 上部署时改这里，不要改容器内路径。
HOST_VIDEO_ROOT=./CourseMind/videos
HOST_UPLOAD_VIDEO_ROOT=./CourseMind/upload-videos
HOST_DATA_DIR=./CourseMind/data
HOST_PROCESSED_DIR=./CourseMind/processed
HOST_LOG_DIR=./CourseMind/logs
HOST_CONFIG_DIR=./CourseMind/config

# 自动扫描。建议开启，让新放入 NAS 的视频自动出现在课程库。
AUTO_SCAN=true
SCAN_INTERVAL_SECONDS=300
SCAN_RECURSIVE=true
VIDEO_EXTENSIONS=.mp4,.m4v,.mov,.webm,.mkv,.avi,.flv,.ts,.mts,.m2ts,.wmv,.mpg,.mpeg,.3gp

# 自动处理。默认关闭，避免一次性处理大量视频产生 API 费用。
AUTO_PROCESS_NEW_VIDEO=false
AUTO_PROCESS_MAX_PER_ROUND=1
PROCESS_CONCURRENCY=1
MAX_RETRY=3
RETRY_DELAY_SECONDS=30
MAX_AUTO_PROCESS_MINUTES_PER_DAY=120
MAX_SINGLE_VIDEO_MINUTES=180

# 音频切片秒数
AUDIO_CHUNK_SECONDS=600

# mock：流程测试，不产生费用
# openai：OpenAI 或 OpenAI-compatible 音频转文字接口
# local_funasr/funasr：本地或局域网 FunASR/OpenAI-compatible ASR 服务
# aliyun_dashscope：阿里云百炼 DashScope，默认模型建议 fun-asr-realtime
# aliyun_paraformer：DashScope provider 兼容别名，当前本地文件闭环用 paraformer-realtime-v2
ASR_PROVIDER=mock
TRANSCRIPTION_PROVIDER=mock
ASR_MODEL=
ASR_LANGUAGE=zh
ASR_SAMPLE_RATE=16000
ASR_VOCABULARY_ID=
ASR_PHRASE_ID=
SUBTITLE_CORRECTION_ENABLED=true
TRANSCRIPTION_MODEL=
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_BASE_URL=
DASHSCOPE_API_KEY=
DASHSCOPE_WEBSOCKET_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference

# OpenAI 兼容参数。TRANSCRIPTION_PROVIDER=openai 时使用。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 章节、重点、笔记分析模型配置。当前规则生成，后续可接真实 summary provider。
SUMMARY_PROVIDER=mock
SUMMARY_MODEL=deepseek-chat
SUMMARY_API_KEY=
SUMMARY_BASE_URL=
ANALYSIS_MODEL=gpt-4.1-mini

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8788,http://127.0.0.1:8788,http://localhost:5173,http://127.0.0.1:5173
